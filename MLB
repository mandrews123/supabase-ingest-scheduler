name: Ingest MLB (every 15m)

on:
  schedule:
    - cron: "*/15 * * * *"
  workflow_dispatch:

jobs:
  call:
    runs-on: ubuntu-latest
    steps:
      - name: Call Supabase Edge Function (mlb)
        run: |
          curl -sSf -X POST \
            "https://dpdbdiwfanenccdvuyao.supabase.co/functions/v1/hyper-function?only=mlb" \
            -H "Content-Type: application/json" \
            -d '{}'
