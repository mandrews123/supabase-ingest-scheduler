name: Ingest NCAA (every 10m)

on:
  schedule:
    - cron: "*/10 * * * *"
  workflow_dispatch:

jobs:
  call:
    runs-on: ubuntu-latest
    steps:
      - name: Call Supabase Edge Function (ncaa)
        run: |
          curl -sSf -X POST \
            "https://dpdbdiwfanenccdvuyao.supabase.co/functions/v1/hyper-function?only=ncaa" \
            -H "Content-Type: application/json" \
            -d '{}'
